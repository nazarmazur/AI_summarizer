# ---- build artifacts ----
dist/
*.zip
!store/assets/*.zip      # promo zips (none yet, but keep door open)

# ---- node / package managers (not used in runtime, but devs may install pdfjs) ----
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.pnp.*

# ---- pdfjs vendored bundle (each contributor copies their own) ----
extension/lib/pdfjs/*.mjs
extension/lib/pdfjs/*.js
extension/lib/pdfjs/*.map

# ---- secrets — never commit ----
.env
.env.*
*.local
extension/lib/config.local.js

# ---- editor / OS junk ----
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---- logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- chrome dev profile leftovers ----
chrome-profile/

# ---- supabase CLI ----
.supabase/
supabase/.branches/
supabase/.temp/

# ---- PNG promo assets are committed; HTML source is committed too ----
# (no exclusions here — assets/ is intentionally checked in)
